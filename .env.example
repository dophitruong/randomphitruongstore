DATABASE_URL="postgresql://postgres:postgres@localhost:5432/random_phitruong?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/random_phitruong?schema=public"
ADMIN_BOOTSTRAP_EMAIL="owner@example.com"
ADMIN_BOOTSTRAP_PASSWORD="replace-with-a-long-random-admin-password"
ADMIN_BOOTSTRAP_NAME="Store Owner"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# "local" for development, "supabase" or "cloudinary" for production
# Supabase driver requires SUPABASE_SERVICE_ROLE_KEY
# Cloudinary driver requires CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, and CLOUDINARY_API_SECRET
UPLOAD_DRIVER="local"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"


# Supabase — get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# SePay Payment Gateway. Keep "sandbox" for the local signed simulator.
# Set "production" only after configuring the HTTPS IPN URL in SePay.
SEPAY_ENVIRONMENT="sandbox"
SEPAY_MERCHANT_ID="your-merchant-id"
SEPAY_MERCHANT_SECRET_KEY="your-merchant-secret-key"
SEPAY_IPN_SECRET_KEY="the-X-Secret-Key-configured-in-SePay"
# Optional dedicated key for local sandbox completion proofs.
SEPAY_SANDBOX_SECRET="replace-with-a-long-random-sandbox-secret"

# Meta Pixel & Conversions API (CAPI)
NEXT_PUBLIC_META_PIXEL_ID="your-meta-pixel-id"
META_ACCESS_TOKEN="your-meta-access-token"

