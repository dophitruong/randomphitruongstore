generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductCategory {
  SUKAJAN
  BOMBER
  HOODIE
  JACKET
  SEASONAL
}

enum ShippingRegion {
  VIETNAM
  KOREA
  TAIWAN
  JAPAN
}

enum PaymentMethod {
  DEPOSIT_50_BANK_ZALO
  ONLINE_100_VNPAY
  ONLINE_100_MOMO
}

enum OrderStatus {
  PENDING_DEPOSIT
  DEPOSIT_CONFIRMED
  PENDING_ONLINE_PAYMENT
  PAID_FULL
  ORDERED_FROM_SUPPLIER
  ARRIVED_AT_SHOP
  SHIPPING
  COMPLETED
  CANCELLED
}

enum OrderRequestStatus {
  NEW
  CONTACTED
  QUOTED
  CLOSED
}

enum AdminRole {
  OWNER
  ADMIN
  STAFF
}

enum InquiryStatus {
  NEW
  CONTACTED
  QUOTED
  CONVERTED_TO_ORDER
  CLOSED
}

enum OrderType {
  CATALOG_PRODUCT
  CUSTOM_INQUIRY
}

enum PaymentOption {
  DEPOSIT_50
  ONLINE_100
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentType {
  DEPOSIT
  REMAINING_BALANCE
  FULL_PAYMENT
  SHIPPING_FEE
}

enum ProofStatus {
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

enum ShipmentStatus {
  PENDING
  READY_TO_SHIP
  SHIPPED
  IN_TRANSIT
  DELIVERED
  RETURNED
  CANCELLED
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
  ARCHIVED
}

enum PageType {
  ABOUT
  CONTACT
  FAQ
  ORDER_GUIDE
  PAYMENT_GUIDE
  SHIPPING_GUIDE
  CUSTOM_PAGE
}

enum SourceChannel {
  WEBSITE
  ZALO
  INSTAGRAM
  TIKTOK
  OTHER
}

enum CustomsIdType {
  RESIDENCE_CARD
  PASSPORT
  VIRTUAL_ID
  NONE
}

model AdminUser {
  id              String    @id @default(uuid()) @db.Uuid
  fullName        String
  email           String    @unique
  passwordHash    String
  role            AdminRole @default(STAFF)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  createdProducts Product[] @relation("ProductCreatedByAdmin")
  updatedOrders   Order[]   @relation("OrderUpdatedByAdmin")

  @@index([role, isActive])
}

model ShopSetting {
  id                String          @id @default(uuid()) @db.Uuid
  brandName         String
  defaultLanguage   String          @default("vi")
  zaloPhone         String
  zaloQrCodeUrl     String?
  orderLeadTimeText String          @default("7-10 ngày")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @default(now()) @updatedAt
  socialLinks       SocialLink[]
  bankAccounts      BankAccount[]
  zaloCommunities   ZaloCommunity[]
}

model SocialLink {
  id            String      @id @default(uuid()) @db.Uuid
  shopSettingId String      @db.Uuid
  shopSetting   ShopSetting @relation(fields: [shopSettingId], references: [id], onDelete: Cascade)
  platform      String
  url           String
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())

  @@unique([shopSettingId, platform])
  @@index([shopSettingId])
}

model BankAccount {
  id             String      @id @default(uuid()) @db.Uuid
  shopSettingId  String      @db.Uuid
  shopSetting    ShopSetting @relation(fields: [shopSettingId], references: [id], onDelete: Cascade)
  bankName       String
  branchName     String?
  accountNumber  String
  accountHolder  String
  vietqrImageUrl String?
  isDefault      Boolean     @default(false)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())

  @@unique([shopSettingId, accountNumber])
  @@index([shopSettingId, isDefault])
}

model ZaloCommunity {
  id            String      @id @default(uuid()) @db.Uuid
  shopSettingId String      @db.Uuid
  shopSetting   ShopSetting @relation(fields: [shopSettingId], references: [id], onDelete: Cascade)
  groupName     String
  groupUrl      String?
  qrCodeUrl     String?
  isActive      Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@unique([shopSettingId, groupName])
  @@index([shopSettingId])
}

model Category {
  id               String     @id @default(uuid()) @db.Uuid
  parentCategoryId String?    @db.Uuid
  parentCategory   Category?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id], onDelete: SetNull)
  subcategories    Category[] @relation("CategoryHierarchy")
  nameVi           String
  nameEn           String
  slug             String     @unique
  descriptionVi    String?    @db.Text
  descriptionEn    String?    @db.Text
  sortOrder        Int        @default(0)
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  products         Product[]

  @@index([parentCategoryId])
  @@index([isActive, sortOrder])
}

model Product {
  id                   String           @id @default(uuid()) @db.Uuid
  nameVi               String
  nameEn               String
  slug                 String           @unique
  descriptionVi        String           @db.Text
  descriptionEn        String           @db.Text
  category             ProductCategory
  categoryId           String?          @db.Uuid
  categoryRecord       Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdByAdminId     String?          @db.Uuid
  createdByAdmin       AdminUser?       @relation("ProductCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  price                Int
  basePrice            Int?
  orderLeadTimeMinDays Int              @default(7)
  orderLeadTimeMaxDays Int              @default(10)
  sizes                String[]
  colors               String[]
  materialVi           String
  materialEn           String
  isFeatured           Boolean          @default(false)
  isActive             Boolean          @default(true)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  images               ProductImage[]
  productInquiries     ProductInquiry[]
  variants             ProductVariant[]
  sizeCharts           SizeChart[]
  orderItems           OrderItem[]

  @@index([category, isActive])
  @@index([categoryId])
  @@index([createdByAdminId])
}

model ProductImage {
  id        String  @id @default(uuid()) @db.Uuid
  url       String
  altVi     String
  altEn     String
  sortOrder Int     @default(0)
  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model ProductVariant {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @db.Uuid
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  size            String
  colorVi         String
  colorEn         String
  priceAdjustment Int      @default(0)
  isAvailable     Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@unique([productId, size, colorVi])
  @@index([productId])
}

model SizeChart {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      String
  shoulder  Decimal? @db.Decimal(6, 2)
  chest     Decimal? @db.Decimal(6, 2)
  length    Decimal? @db.Decimal(6, 2)
  sleeve    Decimal? @db.Decimal(6, 2)
  unit      String   @default("cm")
  createdAt DateTime @default(now())

  @@unique([productId, size])
  @@index([productId])
}

model Customer {
  id                 String              @id @default(uuid()) @db.Uuid
  fullName           String
  phone              String
  email              String?
  zaloPhone          String?
  instagramHandle    String?
  preferredLanguage  String              @default("vi")
  address            String
  province           String
  district           String
  ward               String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  orders             Order[]
  contactSubmissions ContactSubmission[]
  productInquiries   ProductInquiry[]

  @@index([phone])
}

model ContactSubmission {
  id         String        @id @default(uuid()) @db.Uuid
  customerId String?       @db.Uuid
  customer   Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  fullName   String
  phone      String
  email      String?
  channel    SourceChannel @default(WEBSITE)
  message    String        @db.Text
  status     ContactStatus @default(NEW)
  createdAt  DateTime      @default(now())

  @@index([customerId])
  @@index([status, createdAt])
}

model ProductInquiry {
  id                 String         @id @default(uuid()) @db.Uuid
  customerId         String?        @db.Uuid
  customer           Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  productId          String?        @db.Uuid
  product            Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  fullName           String
  phone              String
  email              String?
  zaloPhone          String?
  instagramHandle    String?
  sourceChannel      SourceChannel  @default(WEBSITE)
  externalProductUrl String?
  customerMessage    String?        @db.Text
  preferredSize      String?
  preferredColor     String?
  quotedPrice        Int?
  status             InquiryStatus  @default(NEW)
  quotedAt           DateTime?
  createdAt          DateTime       @default(now())
  images             InquiryImage[]
  convertedOrder     Order?

  @@index([customerId])
  @@index([productId])
  @@index([status, createdAt])
}

model InquiryImage {
  id               String         @id @default(uuid()) @db.Uuid
  inquiryId        String         @db.Uuid
  inquiry          ProductInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  imageUrl         String
  originalFilename String?
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())

  @@index([inquiryId, sortOrder])
}

model Order {
  id                  String          @id @default(uuid()) @db.Uuid
  orderNumber         String          @unique
  customerId          String          @db.Uuid
  customer            Customer        @relation(fields: [customerId], references: [id])
  inquiryId           String?         @unique @db.Uuid
  inquiry             ProductInquiry? @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  updatedByAdminId    String?         @db.Uuid
  updatedByAdmin      AdminUser?      @relation("OrderUpdatedByAdmin", fields: [updatedByAdminId], references: [id], onDelete: SetNull)
  trackingToken       String?         @unique
  orderType           OrderType       @default(CATALOG_PRODUCT)
  paymentOption       PaymentOption?
  shippingRegion      ShippingRegion  @default(VIETNAM)
  paymentMethod       PaymentMethod
  status              OrderStatus
  note                String?         @db.Text
  subtotal            Int
  depositAmount       Int?
  subtotalAmount      Int?
  remainingAmount     Int?
  shippingFee         Int             @default(0)
  totalAmount         Int?
  sizeColorLocked     Boolean         @default(false)
  noChangePolicyAck   Boolean         @default(false)
  noChangePolicyAckAt DateTime?
  expectedArrivalDate DateTime?
  adminNotes          String?         @db.Text
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  items               OrderItem[]

  @@index([status, createdAt])
  @@index([updatedByAdminId])
}

model OrderItem {
  id          String  @id @default(uuid()) @db.Uuid
  orderId     String  @db.Uuid
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String  @db.Uuid
  product     Product @relation(fields: [productId], references: [id])
  productName String
  unitPrice   Int
  quantity    Int     @default(1)
  size        String
  color       String

  @@index([orderId])
}

model OrderRequest {
  id             String             @id @default(uuid()) @db.Uuid
  fullName       String
  phone          String
  socialContact  String
  inspirationUrl String
  desiredSize    String
  desiredColor   String
  note           String?            @db.Text
  status         OrderRequestStatus @default(NEW)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([status, createdAt])
}
